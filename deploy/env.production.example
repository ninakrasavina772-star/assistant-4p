# Скопируйте в корень репозитория как .env.production (не коммитить!)
# Домен должен совпадать с HTTPS в nginx и redirect URI в Google Cloud.

NEXTAUTH_URL=https://assistant.example.com
NEXT_PUBLIC_APP_ORIGIN=https://assistant.example.com
NEXTAUTH_SECRET=сгенерируйте-openssl-rand-base64-32

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=you@company.com,colleague@gmail.com

OPENAI_API_KEY=
# Прокси к OpenAI (обязательно для Yandex VM в РФ, иначе unsupported_country_region_territory)
# OPENAI_BASE_URL=https://your-proxy.example.com

# Инфографика Подружка — публичные ссылки для Ozon (скопируйте с Vercel)
YANDEX_S3_BUCKET=
YANDEX_S3_ACCESS_KEY_ID=
YANDEX_S3_SECRET_ACCESS_KEY=
YANDEX_S3_REGION=ru-central1
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_PREFIX=ozon-images
YANDEX_S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/YOUR_BUCKET

# Опционально: 4Partners, Metabase
# FOURPARTNERS_API_BASE=https://api.4partners.io/v1
# FOURPARTNERS_TOKEN_A=
# METABASE_URL=
# METABASE_API_KEY=
# METABASE_DB_ID=2

# Мониторинг (Telegram-бот): случайная строка, та же в deploy/bot.env
# MONITOR_SECRET=
# MONITOR_LOG_DIR=/opt/assistant-4p/logs
