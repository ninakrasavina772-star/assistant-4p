# Скопируйте в .env.local в корне репозитория (рядом с package.json).
# Файл не коммитить. Секреты выдаёт администратор (из Vercel / Yandex / OpenAI).

# --- Обязательно для инфографики Подружка ---
OPENAI_API_KEY=

YANDEX_S3_BUCKET=
YANDEX_S3_ACCESS_KEY_ID=
YANDEX_S3_SECRET_ACCESS_KEY=
YANDEX_S3_REGION=ru-central1
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_PREFIX=ozon-images
YANDEX_S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/YOUR_BUCKET

# --- Опционально: если нужен раздел /compare (4Partners) ---
# FOURPARTNERS_API_BASE=https://api.4partners.io/v1
# FOURPARTNERS_TOKEN_A=
# FOURPARTNERS_TOKEN_B=
