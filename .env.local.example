# Скопируйте в .env.local (не коммитить!)

# --- Проще для первого раза (только локально, npm run dev): без Google ---
# Раскомментируйте строку ниже — страница /compare откроется без входа.
# На реальный сервер не выкладывайте с COMPARE_SKIP_AUTH=1
# COMPARE_SKIP_AUTH=1

# NextAuth: openssl rand -base64 32
NEXTAUTH_SECRET=
# Публичный URL приложения: порт ДОЛЖЕН совпадать с адресом в браузере
# (если dev на :3001 — укажите http://localhost:3001, иначе сессия может «висеть»)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Список email, кому разрешён вход (через запятую или ;)
# В production обязателен; пусто = вход всем Google запрещён
ALLOWED_EMAILS=you@company.com,colleague@gmail.com

# Только local dev: разрешить любой Google, если true (не для production)
# DEBUG_ALLOW_ANY_GOOGLE=1

# Токены 4Partners — только на сервере, не в браузере
# Один токен на каждую витрину (два разных site_id)
FOURPARTNERS_API_BASE=https://api.4partners.io/v1
FOURPARTNERS_TOKEN_A=
FOURPARTNERS_TOKEN_B=
# Либо один общий, если сравниваете рубрики на той же площадке (редко)
# FOURPARTNERS_TOKEN=

# Подписи в интерфейсе
SITE_A_LABEL=Рив Гош
SITE_B_LABEL=Сайт B

# URL карточки товара в админке (для кнопки «Карточка» на /compare). Обязателен плейсхолдер {id}
# Пример: https://admin.example.com/product/{id} (уточните путь в вашем бэкофисе 4Partners)
# NEXT_PUBLIC_4P_ADMIN_URL_TEMPLATE=

# База для кнопки «Админка» (4stand): по умолчанию https://4stand.com/A — к id подставляется без разделителя (…/A57680301)
# NEXT_PUBLIC_4STAND_ADMIN_BASE=https://4stand.com/A

# --- /ozon-images: ссылки на инфографику для Ozon ---
#
# Рекомендуется для Ozon — Yandex Object Storage (S3-совместимый):
# YANDEX_S3_BUCKET=assistant-4p-ozon
# YANDEX_S3_ACCESS_KEY_ID=
# YANDEX_S3_SECRET_ACCESS_KEY=
# YANDEX_S3_REGION=ru-central1
# YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
# YANDEX_S3_PREFIX=ozon-images
# YANDEX_S3_PUBLIC_BASE_URL=https://storage.yandexcloud.net/assistant-4p-ozon
#
# Запасной вариант — Vercel Blob (Ozon может не принять ссылку в UI):
# BLOB_READ_WRITE_TOKEN=
#
# OZON_IMAGE_ALLOWED_HOSTS=5.35.85.200
# OZON_IMAGE_HTTP_BASE=http://5.35.85.200
